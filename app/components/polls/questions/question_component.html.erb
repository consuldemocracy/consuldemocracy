<% if question.essay? %>
  <div class="poll-question-essay">
    <%= label_tag "web_vote_#{question.id}_text_answer", question.title %>
    <%= text_area "web_vote[#{question.id}]",
                  "text_answer",
                  id: "web_vote_#{question.id}_text_answer",
                  value: existing_answer,
                  rows: 3 %>
  </div>
<% else %>
  <fieldset <%= fieldset_attributes %>>
    <legend><%= question.title %></legend>

    <%= multiple_choice_help_text if multiple_choice? %>

    <% question.question_options.each do |option| %>
      <%= choice_field(option) %>
    <% end %>

    <% if question.options_with_read_more? %>
      <div class="read-more-links">
        <p><%= t("poll_questions.read_more_about") %></p>
        <p><%= options_read_more_links %></p>
      </div>
    <% end %>
    <%= form.error_for(:"question_#{question.id}") %>
  </fieldset>
<% end %>
