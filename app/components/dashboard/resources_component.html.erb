<div id="available-resources-section">
  <h3 class="title"><%= t("dashboard.resources.available_resources") %></h3>

  <div data-equalizer="resources" data-equalize-on="medium">
    <%= render Dashboard::DefaultResourceComponent.with_collection(default_resources, proposal: proposal) %>
    <%= render Dashboard::ActiveResourceComponent.with_collection(
      active_resources, proposal: proposal, new_actions_since_last_login: new_actions_since_last_login
    ) %>
  </div>
</div>
